{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "has": [
          {
            "type": "host",
            "value": "www.structuralsolver.com"
          }
        ],
        "destination": "https://structuralsolver.com",
        "type": 301
      }
    ]
  }
}